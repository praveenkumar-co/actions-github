{
  "name": "task-queue-api",
  "version": "1.0.0",
  "description": "Production-inspired distributed job processing platform — DevOps/SRE learning project",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/server.ts",
    "worker": "node dist/worker/index.js",
    "worker:dev": "nodemon --watch 'worker/**/*.ts' --watch 'src/**/*.ts' --exec 'ts-node' worker/index.ts",
    "test": "jest --runInBand",
    "test:unit": "jest tests/unit --runInBand",
    "test:integration": "jest tests/integration --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "lint": "eslint src worker tests --ext .ts --no-error-on-unmatched-pattern",
    "lint:fix": "eslint src worker tests --ext .ts --fix --no-error-on-unmatched-pattern",
    "format": "prettier --write --no-error-on-unmatched-pattern 'src/**/*.ts' 'worker/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check --no-error-on-unmatched-pattern 'src/**/*.ts' 'worker/**/*.ts' 'tests/**/*.ts'",
    "db:migrate": "ts-node src/db/migrate.ts"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "bullmq": "^5.4.2",
    "express": "^4.18.3",
    "ioredis": "^5.3.2",
    "pino": "^8.19.0",
    "pino-http": "^9.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.43",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testTimeout": 10000,
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "worker/**/*.ts",
      "!src/server.ts"
    ]
  }
}
