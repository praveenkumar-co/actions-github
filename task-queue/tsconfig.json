{
  "compilerOptions": {
    "target": "ES2022",                    
    "module": "CommonJS",                      
    "lib": ["ES2022"],                           
    "outDir": "./dist",                    
    "rootDir": "./",                    
    "strict": true,                          
    "noImplicitAny": true,                     
    "strictNullChecks": true,                  
    "esModuleInterop": true,                 
    "skipLibCheck": true,                      
    "forceConsistentCasingInFileNames": true,    
    "resolveJsonModule": true,
    "types": ["node", "jest"]
  },
  "include": ["src/**/*", "worker/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}